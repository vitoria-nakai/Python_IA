def add_item(list):
    item = input("O que deseja comprar? ").strip().capitalize()
    if item in list:
        print("Esse item já está na lista!")
    else:
        list.append(item)
        print(f"{item} adicionado!")

def remove_item(list):
    remove = int(input("Digite o número do item que deseja remover: "))
    list.remove(list[remove - 1])
    print("Item removido com sucesso!")

